# BengaluruTrafficAI Backend Environment Variables

# Database Configuration
# For local SQLite (development):
# DATABASE_URL=sqlite:///./bengaluru_traffic.db

# For Railway PostgreSQL (production):
# Get this from your Railway dashboard → PostgreSQL → Connect → Connection URL
# DATABASE_URL=postgresql://user:password@host:port/database

# Example Railway PostgreSQL URL format:
# DATABASE_URL=postgresql://postgres:password@containers-us-west-123.railway.app:5432/railway

# API Configuration (optional)
# Used by main.py / upload subprocess to POST violations to the running API
# API_BASE_URL=http://localhost:8000

# Optional YOLO model for plate region detection (improves OCR accuracy)
# PLATE_MODEL_PATH=models/plate_detector.pt
