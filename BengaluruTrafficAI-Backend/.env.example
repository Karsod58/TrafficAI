# BengaluruTrafficAI — Environment Configuration
# Copy this file to .env and fill in your values

# ===== Database Configuration =====
# Railway PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-instance.railway.app:5432/railway

# Alternative: Local PostgreSQL for development
# DATABASE_URL=postgresql://postgres:password@localhost:5432/bengaluru_traffic

# Alternative: SQLite for testing (not recommended for production)
# DATABASE_URL=sqlite:///./bengaluru_traffic.db

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Model Configuration =====
# YOLO model path (yolo11s.pt, yolov8s.pt, or custom)
YOLO_MODEL=yolo11s.pt

# Detection confidence threshold (0.0 - 1.0)
DETECTION_CONFIDENCE=0.42

# Frame skip rate (process every Nth frame)
SKIP_FRAMES=2

# ===== ALPR Configuration =====
# Optional: Custom plate detection model
PLATE_MODEL_PATH=

# ===== Preprocessing Configuration =====
# Enable/disable preprocessing features
ENABLE_CLAHE=true
ENABLE_DENOISE=false
ENABLE_DEBLUR=false

# Target resolution for preprocessing
TARGET_WIDTH=1280
TARGET_HEIGHT=720

# ===== Dataset Management =====
# Roboflow API key for dataset management
# Get from: https://roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Roboflow workspace and project
ROBOFLOW_WORKSPACE=bengaluru-traffic
ROBOFLOW_PROJECT=traffic-violations

# ===== Experiment Tracking =====
# Weights & Biases API key
# Get from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# W&B project name
WANDB_PROJECT=bengaluru-traffic-ai
WANDB_ENTITY=your_wandb_username

# ===== Alert Routing =====
# Peak hour times (HH:MM format)
PEAK_HOUR_START=08:00
PEAK_HOUR_END=10:30
PEAK_HOUR_EVENING_START=17:30
PEAK_HOUR_EVENING_END=20:00

# Repeat offender threshold (number of violations)
REPEAT_OFFENDER_THRESHOLD=3

# ===== Evidence Storage =====
# Evidence output directory
EVIDENCE_DIR=./output/evidence

# Evidence retention days (0 = never delete)
EVIDENCE_RETENTION_DAYS=90

# ===== Redis Configuration (Optional) =====
# Redis for caching and task queue
REDIS_URL=redis://localhost:6379/0

# Alternative: Railway Redis
# REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# ===== Email/SMS Alerts (Optional) =====
# SMTP configuration for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@bengaluru-traffic.gov.in

# Twilio for SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Logging =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log to file
LOG_FILE=logs/bengaluru_traffic.log

# ===== Development Settings =====
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enable detailed error pages)
DEBUG=false

# Enable API docs in production (set to false for security)
ENABLE_DOCS=true

# ===== Security =====
# API key for authenticated endpoints (if implementing auth)
API_SECRET_KEY=your_secret_key_here_change_in_production

# JWT secret for token-based auth (if implementing auth)
JWT_SECRET=your_jwt_secret_here_change_in_production

# ===== Performance =====
# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# ===== Feature Flags =====
# Enable/disable features
ENABLE_PREPROCESSING=true
ENABLE_ALERT_ROUTING=true
ENABLE_API_SUBMISSION=true
ENABLE_WANDB=false
ENABLE_EVIDENCE_GENERATION=true
